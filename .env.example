# ─────────────────────────────────────────────────────────────
# Formation Exceptionelle — Backend environment
# Copy to `.env` and fill in. The server boots with sensible dev
# defaults; every external provider degrades gracefully when its
# keys are missing (video=mock, payments=mock, storage=local,
# email=console). Set a provider + its keys to activate the real one.
# ─────────────────────────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=development
# Comma-separate multiple origins (e.g. local + vercel domain).
CLIENT_ORIGIN=http://localhost:5173

# Database — MongoDB Atlas connection string in production.
MONGODB_URI=mongodb://localhost:27017/formation_exceptionelle

# Auth
JWT_SECRET=replace-with-long-random-string
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# Admin seed (created/updated by `npm run seed`)
SEED_ADMIN_EMAIL=admin@formationexceptionelle.com
SEED_ADMIN_PASSWORD=Admin@2024!

# ── Video — Bunny Stream (recommended) ───────────────────────
# VIDEO_PROVIDER: mock | bunny | mux
VIDEO_PROVIDER=mock
# Bunny Stream → Library → API tab
BUNNY_STREAM_LIBRARY_ID=
BUNNY_STREAM_API_KEY=
BUNNY_STREAM_CDN=          # e.g. vz-xxxxxxxx.b-cdn.net
BUNNY_STREAM_WEBHOOK_SECRET=
# Mux (optional alternative)
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=
MUX_WEBHOOK_SECRET=

# ── Payments — Paystack ──────────────────────────────────────
# PAYMENT_PROVIDER: mock | paystack
PAYMENT_PROVIDER=mock
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
# Where Paystack redirects after payment (a frontend route). Defaults to
# CLIENT_ORIGIN/checkout/callback when blank.
PAYSTACK_CALLBACK_URL=

# ── File storage — Cloudflare R2 ─────────────────────────────
# STORAGE_DRIVER: local | r2
STORAGE_DRIVER=local
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=            # public bucket URL or custom domain, e.g. https://files.yourdomain.com

# ── Email — Resend (recommended) ─────────────────────────────
# MAIL_TRANSPORT: console | resend | smtp
MAIL_TRANSPORT=console
RESEND_API_KEY=
# SMTP (only if MAIL_TRANSPORT=smtp)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM="Formation Exceptionelle <no-reply@formationexceptionelle.com>"

# Uploads (local disk caps; also enforced before cloud upload)
UPLOAD_DIR=uploads
MAX_VIDEO_MB=512
MAX_IMAGE_MB=2
MAX_CV_MB=5
